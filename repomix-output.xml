    def push_event(self, message: str) -> None:
        ts = time.strftime("%H:%M:%S")
        entry = f"[{ts}] {message}"
        self.events.insert(0, entry)
        if len(self.events) > self.max_events:
            self.events.pop()

    def clamp_ue(self, x: int, y: int) -> Tuple[int, int]:
